---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import SiteWizard from '../../../components/admin/local/SiteWizard';
---
<AdminLayout title="Criar meu site" activeSection="local-templates">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-ink">Criar meu site</h1>
        <p class="text-ink-muted mt-1">Em 3 passos: escolha o ramo, diga onde você atende e pronto — suas páginas são criadas.</p>
    </div>
    <SiteWizard client:load />
</AdminLayout>
